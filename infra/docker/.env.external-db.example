# Helix Helpdesk - External Database Configuration
# Copy this to .env and customize for your environment

# Environment
NODE_ENV=development

# Database (update these to match your existing PostgreSQL)
# Use host.docker.internal on Windows/Mac, or host.containers.internal on some setups
DATABASE_URL=postgresql://helix:helix_secret@host.docker.internal:5432/helix_helpdesk

# Redis - Use Docker service name 'redis' when Redis is managed by docker-compose
# If using an existing Redis container, connect it to the 'docker_helix-network'
REDIS_URL=redis://redis:6379

# JWT Secrets - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-256-bit-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars

# License System - Must match the LICENSE_SECRET used to generate license tokens
LICENSE_SECRET=your-super-secret-license-key-change-in-production

# URLs
ALLOWED_ORIGINS=http://localhost,http://localhost:5173
APP_URL=http://localhost
API_URL=http://localhost:3000

# ===============
# Optional Settings
# ===============

# Azure AD SSO
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/azure/callback

# Email (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=tickets@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@helix.helpdesk

# Email (IMAP/Inbound)
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=tickets@example.com
# IMAP_PASSWORD=your-imap-password

# Storage
# STORAGE_TYPE=local
# AWS_S3_BUCKET=helix-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# AI Chatbot
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-api-key
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com