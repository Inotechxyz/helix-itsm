# Environment
NODE_ENV=development
PORT=3000

# Database
# IMPORTANT: Replace with your actual database connection string
# Use a secure password with at least 16 characters
# For production, add connection pool settings:
# postgresql://username:password@host:5432/db?connection_limit=10&pool_timeout=20
DATABASE_URL=postgresql://username:strong-password@localhost:5432/helix_helpdesk

# Performance Settings
# Slow query threshold in milliseconds (queries slower than this are logged)
SLOW_QUERY_THRESHOLD_MS=1000

# Report query limits (to prevent memory exhaustion during stress testing)
MAX_DATE_RANGE_DAYS=90
MAX_RECORDS_FETCH=10000

# Redis
REDIS_URL=redis://localhost:6379

# Redis Cache (Server-side caching to reduce database load)
# Set to 'false' to disable server-side caching (useful when Redis is for Bull queues only)
REDIS_CACHE_ENABLED=true
# Cache TTL settings (in milliseconds)
REDIS_CACHE_TTL_SHORT=30000       # 30 seconds - for frequently changing data (dashboard)
REDIS_CACHE_TTL_MEDIUM=300000      # 5 minutes - for moderately static data
REDIS_CACHE_TTL_LONG=900000        # 15 minutes - for static data (categories, teams)
REDIS_CACHE_TTL_VERY_LONG=3600000  # 1 hour - for rarely changing data (config, policies)

# JWT
# IMPORTANT: Generate strong random secrets (minimum 256-bit)
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_strong_random_secret_minimum_256bits
JWT_REFRESH_SECRET=CHANGE_ME_generate_strong_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Azure AD / Microsoft Entra SSO (Optional)
# See docs/AZURE_SSO_INTEGRATION.md for setup instructions
AZURE_AD_CLIENT_ID=your-azure-application-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret-value
AZURE_AD_TENANT_ID=your-azure-tenant-id
AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/azure/callback

# Email (SMTP) - Optional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=CHANGE_ME_secure_password
# SMTP_FROM="Helix Helpdesk <noreply@example.com>"

# Email (IMAP - for inbound emails) - Optional
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=tickets@example.com
# IMAP_PASSWORD=CHANGE_ME_secure_password
# IMAP_SECURE=true

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# Cloud Storage (Optional - for S3 or Azure Blob)
# AWS_S3_BUCKET=helix-uploads
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_REGION=us-east-1
# AZURE_STORAGE_CONNECTION_STRING=CHANGE_ME
# AZURE_STORAGE_CONTAINER=helix-uploads

# App Configuration
# IMPORTANT: Update these for production
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# CORS - Comma-separated list of allowed origins for production
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Admin User - DO NOT USE IN PRODUCTION
# Admin account should be created via secure deployment process
# ADMIN_USER=admin@helix.local
# ADMIN_PASSWORD=CHANGE_ME_use_strong_password_minimum_12_chars

# ===============================
# Embedding / Semantic Search Configuration
# ===============================
# Note: Semantic search requires pgvector extension to be enabled in PostgreSQL

# Text chunking settings (words per chunk)
EMBEDDING_CHUNK_SIZE=500
EMBEDDING_CHUNK_OVERLAP=50

# Batch processing settings for bulk rebuilds
EMBEDDING_BATCH_SIZE=10
EMBEDDING_RATE_LIMIT=50  # Requests per minute (to avoid API rate limits)

# Retry and resilience settings
EMBEDDING_MAX_RETRIES=3
EMBEDDING_CIRCUIT_BREAKER_THRESHOLD=10  # Failures before circuit opens
EMBEDDING_CIRCUIT_BREAKER_RESET_MS=30000  # Circuit reset after 30 seconds

# System-wide API keys (per-organization keys take precedence)
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
