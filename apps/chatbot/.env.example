# Environment
NODE_ENV=development
PORT=3001

# Database
# IMPORTANT: Replace with your actual database connection string
# Use a secure password with at least 16 characters
DATABASE_URL=postgresql://username:strong-password@localhost:5432/helix_helpdesk

# Redis (optional - for future distributed caching)
REDIS_URL=redis://localhost:6379

# JWT
# IMPORTANT: Must match the API's JWT_SECRET for authentication to work
JWT_SECRET=CHANGE_ME_generate_strong_random_secret_minimum_256bits

# CORS - Comma-separated list of allowed origins for production
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# License Settings
# IMPORTANT: Must match the API's license settings
LICENSE_SECRET=CHANGE_ME_license_secret
LICENSE_PUBLIC_KEY=your-public-key-here

# Logging
LOG_LEVEL=log