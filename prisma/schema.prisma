// ============================================
// Advanced SLA Management
// ============================================

// Configurable SLA Policies
model SlaPolicy {
  id                  String              @id @default(uuid())
  name                String
  description         String?
  isActive            Boolean             @default(true)
  priority            TicketPriority // Which priority level this applies to
  ticketType          TicketType? // Optional: specific ticket type
  categoryId          String? // Optional: specific category
  userTier            UserTier? // Optional: specific user tier
  responseTimeHours   Int // First Response Time target in hours
  resolutionTimeHours Int // Resolution Time target in hours
  warningThreshold    Int                 @default(75) // Percentage to send warning (e.g., 75%)
  organizationId      String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  tickets             Ticket[]
  escalationRules     SlaEscalationRule[]
  organization        Organization?       @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
  @@index([priority])
  @@index([ticketType])
  @@index([isActive])
  @@index([organizationId])
  @@index([organizationId, isActive, priority])
}

// SLA Escalation Rules
model SlaEscalationRule {
  id               String              @id @default(uuid())
  name             String
  description      String?
  slaPolicyId      String
  priority         TicketPriority // Which priority this rule applies to
  condition        EscalationCondition
  thresholdHours   Int // Hours after which this rule triggers
  action           EscalationAction
  actionTarget     String? // Target team/user ID for escalation
  notifyManager    Boolean             @default(false)
  increasePriority Boolean             @default(false)
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  slaPolicy        SlaPolicy           @relation(fields: [slaPolicyId], references: [id], onDelete: Cascade)

  @@index([slaPolicyId])
  @@index([isActive])
}

// Ticket Escalation History
model TicketEscalation {
  id            String           @id @default(uuid())
  ticketId      String
  ruleId        String?
  reason        String
  previousLevel Int              @default(0)
  newLevel      Int              @default(1)
  actionTaken   EscalationAction
  notifiedUsers String[] // Array of user IDs notified
  createdAt     DateTime         @default(now())
  ticket        Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

// OLA (Operational Level Agreement) for internal team handoffs
model OlaPolicy {
  id                  String        @id @default(uuid())
  name                String
  description         String?
  isActive            Boolean       @default(true)
  fromTeamType        TeamType // Source team type
  toTeamType          TeamType // Target team type
  responseTimeHours   Int // Target response time for handoff
  resolutionTimeHours Int // Target resolution time for handoff
  organizationId      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  organization        Organization? @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
  @@index([fromTeamType])
  @@index([toTeamType])
  @@index([isActive])
  @@index([organizationId])
  @@index([fromTeamType, toTeamType, isActive])
}

// Track team handoffs
model OlaHandoff {
  id               String        @id @default(uuid())
  ticketId         String
  organizationId   String?
  fromTeamId       String
  toTeamId         String
  initiatedById    String
  responseDeadline DateTime? // When response is expected
  resolvedDeadline DateTime? // When resolution is expected
  responseAt       DateTime? // When response was sent
  resolvedAt       DateTime? // When resolution was sent
  responseMet      Boolean?
  resolutionMet    Boolean?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization? @relation(fields: [organizationId], references: [id])

  @@index([ticketId])
  @@index([fromTeamId])
  @@index([toTeamId])
  @@index([organizationId])
}

// Enums for SLA
enum EscalationCondition {
  not_assigned // Ticket not assigned within threshold
  no_response // No first response within threshold
  no_update // No update/comment within threshold
  approaching_breach // SLA deadline approaching (percentage)
}

enum EscalationAction {
  notify_agent
  notify_manager
  notify_team
  escalate_to_team
  increase_priority
  auto_assign
  send_email
}

