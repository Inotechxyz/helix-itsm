generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Organization / Multi-tenancy Models
// ============================================

model Organization {
  id        String             @id @default(uuid())
  name      String
  slug      String             @unique
  status    OrganizationStatus @default(active)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?

  // Branding settings
  logoUrl          String?
  primaryColor     String  @default("#0066CC")
  secondaryColor   String  @default("#6B7280")
  faviconUrl       String?
  emailFromName    String?
  emailFooterText  String?
  emailFooterLinks Json? // [{ label: string, url: string }]

  // Relations
  emailTemplates OrganizationEmailTemplate[]

  // Auth configuration
  authProviderType   OrganizationAuthProvider @default(local)
  authProviderConfig Json?

  // Azure AD SSO Configuration (per-organization)
  azureAdEnabled      Boolean @default(false)
  azureAdClientId     String?
  azureAdClientSecret String?
  azureAdTenantId     String?
  azureAdRedirectUri  String?

  // Per-organization Email Configuration (SMTP/IMAP)
  // JSON structure: { smtp: { host, port, secure, user, pass, fromAddress, fromName }, imap: { host, port, secure, user, pass, inboxFolder } }
  emailSettings Json?

  // Subscription/Limits (legacy - now controlled by license token)
  maxUsers   Int @default(50)
  maxStorage Int @default(10) // GB

  // License Token (JWT signed license)
  licenseToken       String?   @unique
  licenseActivatedAt DateTime?

  // Relations
  users             OrganizationUser[]
  invitations       OrganizationInvitation[]
  teams             Team[]
  tickets           Ticket[]
  categories        Category[]
  comments          Comment[]
  attachments       Attachment[]
  articleCategories ArticleCategory[]
  articles          Article[]
  serviceCategories ServiceCategory[]
  services          Service[]
  serviceRequests   ServiceRequest[]
  assetTypes        AssetType[]
  assets            Asset[]
  slaPolicies       SlaPolicy[]
  olaPolicies       OlaPolicy[]
  olaHandovers      OlaHandoff[]
  problems          Problem[]
  changes           ChangeRequest[]
  changeCategories  ChangeCategory[]
  software          Software[]
  softwareLicenses  SoftwareLicense[]
  csatConfigs       CsatSurveyConfig[]
  cabMeetings       CABMeeting[]
  chatbotSessions   ChatbotSession[]
  chatbotConfigs    ChatbotConfig[]

  @@index([slug])
  @@index([status])
}

model OrganizationUser {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  orgRole        OrganizationRole @default(requester)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, orgRole])
}

// Organization Invitation
model OrganizationInvitation {
  id             String                @id @default(uuid())
  organizationId String
  email          String
  role           OrganizationRole      @default(requester)
  token          String                @unique
  status         OrganizationInvStatus @default(pending)
  invitedBy      String // User ID who sent the invitation
  message        String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@index([status])
}

// Organization Email Template - customizable email templates per organization
model OrganizationEmailTemplate {
  id             String            @id @default(uuid())
  organizationId String
  templateType   EmailTemplateType
  subject        String
  body           String            @db.Text // HTML content
  isCustomized   Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, templateType])
  @@index([organizationId])
}

enum OrganizationInvStatus {
  pending
  accepted
  declined
  expired
}

// Enums for Organization
enum OrganizationStatus {
  active
  suspended
  pending
}

enum OrganizationRole {
  orgadmin
  manager
  approver
  agent
  requester
}

enum OrganizationTier {
  starter
  standard
  premium
  enterprise
}

enum OrganizationAuthProvider {
  local
  azure_ad
  google
  saml
  okta
}

// Email template types for organization customization
enum EmailTemplateType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_UPDATED
  TICKET_RESOLVED
  TICKET_CLOSED
  TICKET_COMMENT
  SERVICE_REQUEST_SUBMITTED
  SERVICE_REQUEST_APPROVED
  SERVICE_REQUEST_REJECTED
  SERVICE_REQUEST_COMPLETED
  PASSWORD_RESET
  EMAIL_VERIFICATION
  ORG_INVITATION
}

model User {
  id                 String                      @id @default(uuid())
  email              String                      @unique
  password           String?
  firstName          String
  lastName           String
  role               UserRole                    @default(user)
  tier               UserTier                    @default(standard) // For tier-based SLA
  jobTitle           String?
  department         String?
  phone              String?
  avatarUrl          String?
  isActive           Boolean                     @default(true)
  azureAdId          String?                     @unique
  authProvider       AuthProvider                @default(local)
  primaryTeamId      String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  deletedAt          DateTime?
  articleApprovals   Article[]                   @relation("ArticleApprovedBy")
  articleAssignments Article[]                   @relation("ArticleAssignedTo")
  createdArticles    Article[]                   @relation("ArticleCreator")
  attachments        Attachment[]
  comments           Comment[]
  createdServices    Service[]                   @relation("ServiceCreator")
  approvedRequests   ServiceRequest[]            @relation("ServiceRequestApprovedBy")
  approvals          ServiceRequest[]            @relation("ServiceRequestApprover")
  serviceRequests    ServiceRequest[]            @relation("ServiceRequestRequester")
  teamLeads          Team[]                      @relation("TeamLead")
  assignedTickets    Ticket[]                    @relation("TicketAgent")
  createdTickets     Ticket[]                    @relation("TicketRequester")
  teams              UserTeam[]
  assignedAssets     Asset[]
  changeRequests     ChangeRequest[]             @relation("ChangeRequestRequester")
  changeAssignments  ChangeRequest[]             @relation("ChangeRequestAssignee")
  changeApprovals    ChangeRequest[]             @relation("ChangeRequestApprover")
  changeRejections   ChangeRequest[]             @relation("ChangeRequestRejector")
  licenseAssignments SoftwareLicenseAssignment[]
  organizationUsers  OrganizationUser[]
  chatbotSessions    ChatbotSession[]

  @@index([email])
  @@index([azureAdId])
}

model Team {
  id                String        @id @default(uuid())
  name              String
  type              TeamType
  description       String?
  isActive          Boolean       @default(true)
  leadId            String?
  organizationId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  defaultCategories Category[]
  services          Service[]
  lead              User?         @relation("TeamLead", fields: [leadId], references: [id])
  tickets           Ticket[]
  members           UserTeam[]
  organization      Organization? @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
  @@index([organizationId])
}

model UserTeam {
  id        String   @id @default(uuid())
  userId    String
  teamId    String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model Category {
  id             String        @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  parentId       String?
  defaultTeamId  String?
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  defaultTeam    Team?         @relation(fields: [defaultTeamId], references: [id])
  parent         Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[]    @relation("CategoryHierarchy")
  tickets        Ticket[]
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([name])
  @@index([parentId])
  @@index([organizationId])
}

model Ticket {
  id                    String                @id @default(uuid())
  ticketNumber          String
  channel               TicketChannel         @default(manual)
  type                  TicketType
  status                TicketStatus          @default(new)
  priority              TicketPriority        @default(medium)
  title                 String
  description           String
  requesterId           String
  assignedAgentId       String?
  assignedTeamId        String?
  categoryId            String?
  organizationId        String?
  firstResponseAt       DateTime?
  firstResponseDeadline DateTime? // First Response Time target
  frtBreached           Boolean               @default(false)
  resolvedAt            DateTime?
  closedAt              DateTime?
  slaDeadline           DateTime? // Resolution Time target
  slaBreached           Boolean               @default(false)
  slaBreachNotified     Boolean               @default(false)
  lastActivityAt        DateTime? // For escalation tracking
  escalationLevel       Int                   @default(0) // Track how many times escalated
  externalId            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  slaPolicy             SlaPolicy?            @relation(fields: [slaPolicyId], references: [id])
  slaPolicyId           String?
  attachments           Attachment[]
  comments              Comment[]
  linkedTicket          ServiceRequest?       @relation("ServiceRequestToTicket")
  assignedAgent         User?                 @relation("TicketAgent", fields: [assignedAgentId], references: [id])
  assignedTeam          Team?                 @relation(fields: [assignedTeamId], references: [id])
  category              Category?             @relation(fields: [categoryId], references: [id])
  requester             User                  @relation("TicketRequester", fields: [requesterId], references: [id])
  statusHistory         TicketStatusHistory[]
  assets                AssetTicket[]
  problemLinks          ProblemIncident[]
  linkedToChanges       ChangeLinkedTicket[]
  escalations           TicketEscalation[]
  csatSurvey            CsatSurvey?
  organization          Organization?         @relation(fields: [organizationId], references: [id])

  @@unique([ticketNumber, organizationId])
  @@index([status])
  @@index([priority])
  @@index([requesterId])
  @@index([assignedAgentId])
  @@index([assignedTeamId])
  @@index([slaDeadline])
  @@index([status, slaDeadline])
  @@index([assignedTeamId, status])
  @@index([priority, status])
  @@index([type, createdAt])
  @@index([organizationId])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, assignedAgentId, status])
  @@index([organizationId, priority, status])
}

model TicketStatusHistory {
  id          String        @id @default(uuid())
  ticketId    String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  changedById String
  changedBy   String
  reason      String?
  createdAt   DateTime      @default(now())
  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model Comment {
  id                String        @id @default(uuid())
  ticketId          String
  authorId          String
  content           String
  isInternal        Boolean       @default(false)
  // Email-related fields for reply functionality
  channel           String?       @default("web") // web, email, chat, phone, api
  replyToAddresses  String? // Comma-separated email addresses for email replies
  originalMessageId String? // Original email Message-ID for threading
  originalSubject   String? // Original email subject for reference
  organizationId    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  author            User          @relation(fields: [authorId], references: [id])
  ticket            Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id])

  @@index([ticketId])
  @@index([authorId])
  @@index([channel])
  @@index([organizationId])
  @@index([ticketId, createdAt])
  @@index([ticketId, isInternal])
}

model Attachment {
  id             String        @id @default(uuid())
  ticketId       String? // Optional - required when linked to a ticket, null for chatbot attachments
  uploadedById   String
  filename       String
  originalName   String
  fileSize       Int
  mimeType       String
  storagePath    String
  url            String
  description    String?
  organizationId String?
  createdAt      DateTime      @default(now())
  ticket         Ticket?       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy     User          @relation(fields: [uploadedById], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([ticketId])
  @@index([uploadedById])
  @@index([organizationId])
}

model ArticleCategory {
  id             String            @id @default(uuid())
  name           String
  slug           String
  description    String?
  icon           String?
  color          String?
  sortOrder      Int               @default(0)
  isActive       Boolean           @default(true)
  parentId       String?
  organizationId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  articles       Article[]
  parent         ArticleCategory?  @relation("ArticleCategoryHierarchy", fields: [parentId], references: [id])
  children       ArticleCategory[] @relation("ArticleCategoryHierarchy")
  organization   Organization?     @relation(fields: [organizationId], references: [id])

  @@unique([slug, organizationId])
  @@index([parentId])
  @@index([organizationId])
}

model Tag {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  description String?
  color       String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  articles    ArticleTag[]

  @@index([slug])
}

model Article {
  id              String            @id @default(uuid())
  title           String
  slug            String
  content         String
  summary         String?
  status          ArticleStatus     @default(draft)
  categoryId      String
  organizationId  String?
  metaTitle       String?
  metaDescription String?
  views           Int               @default(0)
  helpfulYes      Int               @default(0)
  helpfulNo       Int               @default(0)
  relatedTickets  String?
  assignedToId    String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  publishedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  approvedBy      User?             @relation("ArticleApprovedBy", fields: [approvedById], references: [id])
  assignedTo      User?             @relation("ArticleAssignedTo", fields: [assignedToId], references: [id])
  category        ArticleCategory   @relation(fields: [categoryId], references: [id])
  createdBy       User              @relation("ArticleCreator", fields: [createdById], references: [id])
  feedbacks       ArticleFeedback[]
  tags            ArticleTag[]
  viewRecords     ArticleView[]
  organization    Organization?     @relation(fields: [organizationId], references: [id])
  embeddings      ArticleEmbedding[]

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([status, categoryId])
  @@index([status, createdAt])
  @@index([organizationId])
}

model ArticleTag {
  id        String  @id @default(uuid())
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model ArticleView {
  id        String   @id @default(uuid())
  articleId String
  viewerIp  String?
  userAgent String?
  viewedAt  DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([viewedAt])
}

model ArticleFeedback {
  id        String   @id @default(uuid())
  articleId String
  helpful   Boolean
  userIp    String?
  userAgent String?
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// Article embeddings for semantic search
model ArticleEmbedding {
  id         String @id @default(uuid())
  articleId  String
  chunkIndex Int    @default(0)
  content    String // Text chunk for reference
  vector     Float[] // Vector embedding (1536 dimensions for DeepSeek/OpenAI embedding models)

  article    Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ServiceCategory {
  id             String        @id @default(uuid())
  name           String
  slug           String
  description    String?
  icon           String?
  color          String?
  sortOrder      Int           @default(0)
  isActive       Boolean       @default(true)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  services       Service[]
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([slug])
  @@index([organizationId])
}

model ChangeCategory {
  id             String          @id @default(uuid())
  name           String
  description    String?
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  organizationId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  changes        ChangeRequest[]
  organization   Organization?   @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Service {
  id                String           @id @default(uuid())
  name              String
  slug              String
  description       String?
  shortDescription  String?
  status            ServiceStatus    @default(draft)
  categoryId        String
  organizationId    String?
  price             Decimal?         @db.Decimal(10, 2)
  currency          String           @default("USD")
  deliveryTimeDays  Int?
  requiresApproval  Boolean          @default(true)
  autoFulfill       Boolean          @default(false)
  autoFulfillAction String?
  slaHours          Int?
  formFields        Json?
  instructions      String?
  relatedKbArticles String?
  assignedTeamId    String?
  assignedAgentId   String?
  requestCount      Int              @default(0)
  completionRate    Decimal?         @db.Decimal(5, 2)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  assignedAgent     User?            @relation("ServiceCreator", fields: [assignedAgentId], references: [id])
  assignedTeam      Team?            @relation(fields: [assignedTeamId], references: [id])
  category          ServiceCategory  @relation(fields: [categoryId], references: [id])
  requests          ServiceRequest[]
  organization      Organization?    @relation(fields: [organizationId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([organizationId])
}

model ServiceRequest {
  id               String               @id @default(uuid())
  requestNumber    String               @unique
  serviceId        String
  requesterId      String
  organizationId   String?
  status           ServiceRequestStatus @default(draft)
  justification    String?
  formData         Json?
  approvalRequired Boolean              @default(true)
  approverId       String?
  approvedById     String?
  approvedAt       DateTime?
  approvalComments String?
  slaDeadline      DateTime?
  slaBreached      Boolean              @default(false)
  linkedTicketId   String?              @unique
  linkedTicket     Ticket?              @relation("ServiceRequestToTicket", fields: [linkedTicketId], references: [id])
  completedAt      DateTime?
  completionNotes  String?
  userFeedback     String?
  rating           Int?
  submittedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  approvedBy       User?                @relation("ServiceRequestApprovedBy", fields: [approvedById], references: [id])
  approver         User?                @relation("ServiceRequestApprover", fields: [approverId], references: [id])
  requester        User                 @relation("ServiceRequestRequester", fields: [requesterId], references: [id])
  service          Service              @relation(fields: [serviceId], references: [id])
  organization     Organization?        @relation(fields: [organizationId], references: [id])

  @@index([requestNumber])
  @@index([status])
  @@index([serviceId])
  @@index([requesterId])
  @@index([slaDeadline])
  @@index([status, createdAt])
  @@index([organizationId])
  @@index([organizationId, status, createdAt])
}

model AuditLog {
  id              String   @id @default(uuid())
  action          String // CREATE, UPDATE, DELETE, CREATE_FAILED, UPDATE_FAILED, DELETE_FAILED
  entityType      String // e.g., "tickets", "users", "organizations"
  entityId        String // ID of the affected entity
  organizationId  String? // Org-scoped isolation
  userId          String?
  userEmail       String?
  userRole        String?
  changes         Json? // Before/after values for updates
  metadata        Json? // Additional context (error messages, etc.)
  method          String? // HTTP method (POST, PUT, PATCH, DELETE)
  path            String? // Request path
  ipAddress       String?
  userAgent       String?
  executionTimeMs Int?
  statusCode      Int? // Response status code
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([organizationId])
  @@index([statusCode])
  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, createdAt])
  @@index([organizationId, action, createdAt])
  @@index([userId, createdAt])
}

model EmailQueue {
  id          String    @id @default(uuid())
  type        String
  direction   String
  fromAddress String
  toAddress   String
  subject     String
  body        String
  htmlBody    String?
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  metadata    Json?
  scheduledAt DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

enum UserRole {
  user
  superadmin
}

// User tier for tier-based SLA policies
enum UserTier {
  standard // Default tier
  premium // Higher priority SLA
  enterprise // Highest priority SLA
  vip // Executive/priority support
}

enum TicketType {
  incident
  service_request
}

enum TicketStatus {
  new
  assigned
  in_progress
  pending
  resolved
  closed
}

enum TicketPriority {
  critical
  high
  medium
  low
}

enum TicketChannel {
  manual
  email
  others
}

enum TeamType {
  first_line
  second_line
  third_line
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ServiceStatus {
  draft
  active
  inactive
  retired
}

enum ServiceRequestStatus {
  draft
  submitted
  pending_approval
  approved
  rejected
  in_progress
  completed
  cancelled
}

enum AuthProvider {
  azure_ad
  local
}

// Asset Management / CMDB
model AssetType {
  id             String        @id @default(uuid())
  name           String
  slug           String
  description    String?
  icon           String?
  color          String?
  sortOrder      Int           @default(0)
  isActive       Boolean       @default(true)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  assets         Asset[]
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([slug])
  @@index([organizationId])
}

model Asset {
  id                  String                      @id @default(uuid())
  name                String
  assetTag            String?
  serialNumber        String?
  typeId              String
  organizationId      String?
  status              AssetStatus                 @default(active)
  manufacturer        String?
  model               String?
  version             String?
  vendor              String?
  purchaseDate        DateTime?
  purchaseCost        Decimal?                    @db.Decimal(12, 2)
  warrantyExpiry      DateTime?
  location            String?
  department          String?
  assignedToId        String?
  assignedToType      AssignedToType?
  ipAddress           String?
  macAddress          String?
  hostname            String?
  operatingSystem     String?
  cpu                 String?
  ram                 String?
  storage             String?
  notes               String?
  metadata            Json?
  lastInventoryAt     DateTime?
  // CMDB Enhancement: CI Classification
  businessCriticality CiCriticality               @default(moderate)
  technicalComplexity CiComplexity                @default(standard)
  ciClass             CiClass?
  riskLevel           RiskLevel?
  configurationItems  Json? // Store configuration item attributes as JSON
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  deletedAt           DateTime?
  type                AssetType                   @relation(fields: [typeId], references: [id])
  assignedTo          User?                       @relation(fields: [assignedToId], references: [id])
  parentAssetId       String?
  parentAsset         Asset?                      @relation("AssetHierarchy", fields: [parentAssetId], references: [id])
  childAssets         Asset[]                     @relation("AssetHierarchy")
  relationshipsFrom   AssetRelationship[]         @relation("AssetRelationshipFrom")
  relationshipsTo     AssetRelationship[]         @relation("AssetRelationshipTo")
  tickets             AssetTicket[]
  maintenanceRecords  AssetMaintenance[]
  affectedByChanges   ChangeAffectedAsset[]
  licenseAssignments  SoftwareLicenseAssignment[]
  organization        Organization?               @relation(fields: [organizationId], references: [id])

