  scheduledStartDate DateTime?
  scheduledEndDate   DateTime?
  actualStartDate    DateTime?
  actualEndDate      DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  rejectedReason     String?
  closureNotes       String?
  organizationId     String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Relations
  changeCategoryId String?
  requester        User?                 @relation("ChangeRequestRequester", fields: [requestedById], references: [id])
  assignee         User?                 @relation("ChangeRequestAssignee", fields: [assignedToId], references: [id])
  approver         User?                 @relation("ChangeRequestApprover", fields: [approvedById], references: [id])
  rejector         User?                 @relation("ChangeRequestRejector", fields: [rejectedById], references: [id])
