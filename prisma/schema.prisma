// ============================================
// CSAT (Customer Satisfaction) Surveys
// ============================================

// Survey configuration - when/how surveys are sent
model CsatSurveyConfig {
  id                 String         @id @default(uuid())
  name               String
  description        String?
  isActive           Boolean        @default(true)
  sendDelayHours     Int            @default(24) // Hours after resolution to send
  reminderDelayHours Int            @default(72) // Hours after first send to send reminder
  maxReminders       Int            @default(2) // Maximum reminder emails
  minTicketAgeHours  Int            @default(1) // Minimum ticket age to send survey
  requireComment     Boolean        @default(false) // Require additional comment
  organizationId     String?
  questions          CsatQuestion[]
  surveys            CsatSurvey[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  organization       Organization?  @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
  @@index([isActive])
  @@index([organizationId])
}

// Survey questions
model CsatQuestion {
  id           String           @id @default(uuid())
  configId     String
  questionText String
  questionType CsatQuestionType @default(rating)
  isRequired   Boolean          @default(true)
  scaleMin     Int              @default(1) // For rating scales
  scaleMax     Int              @default(5)
  orderIndex   Int              @default(0)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  config       CsatSurveyConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  responses    CsatResponse[]

  @@index([configId])
}

// Individual survey responses
model CsatSurvey {
  id             String           @id @default(uuid())
  ticketId       String           @unique // One survey per ticket
  configId       String
  status         CsatSurveyStatus @default(pending)
  sentAt         DateTime?
  firstViewedAt  DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?
  reminderCount  Int              @default(0)
  lastReminderAt DateTime?
  rating         Int? // Overall rating (1-5)
  comment        String? // Optional comment
  responses      CsatResponse[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  ticket         Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  config         CsatSurveyConfig @relation(fields: [configId], references: [id])

  @@index([ticketId])
  @@index([status])
  @@index([sentAt])
  @@index([completedAt])
}

// Individual question responses
model CsatResponse {
  id          String       @id @default(uuid())
  surveyId    String
  questionId  String
  ratingValue Int? // For rating questions
  textValue   String? // For text/feedback questions
  createdAt   DateTime     @default(now())
  survey      CsatSurvey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question    CsatQuestion @relation(fields: [questionId], references: [id])

  @@index([surveyId])
  @@index([questionId])
}

// Enums for CSAT
enum CsatSurveyStatus {
  pending // Survey created but not yet sent
  sent // Survey email sent
  viewed // User opened the survey
  completed // User submitted the survey
  expired // Survey expired without response
  opted_out // User opted out of surveys
}

enum CsatQuestionType {
  rating // 1-5 star rating
  nps // Net Promoter Score (0-10)
  satisfaction // Yes/No satisfaction question
  comment // Free text comment
  thumbs // Thumbs up/down
}

// ============================================
// AI Chatbot Models
// ============================================

// Chatbot session - tracks user conversations
model ChatbotSession {
  id             String @id @default(uuid())
  sessionId      String @unique
  userId         String
  organizationId String

  // Session state
  status        ChatbotSessionStatus @default(active)
  lastMessageAt DateTime             @default(now())
  createdAt     DateTime             @default(now())
  closedAt      DateTime?

  // Context (cached from user/org)
  userEmail     String?
  userFirstName String?
  userLastName  String?
  userOrgRole   String?

  // Analytics
  messageCount Int @default(0)

  // Relations
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ChatbotMessage[]

  @@index([organizationId, status])
  @@index([userId])
  @@index([lastMessageAt])
}

enum ChatbotSessionStatus {
  active
  awaiting_response
  escalated
  resolved
  closed
}

// Chat message - individual messages in conversation
model ChatbotMessage {
  id        String @id @default(uuid())
  sessionId String
  messageId String @unique

  // Content
  role        ChatMessageRole // user, assistant, system
  content     String
  contentType ChatContentType @default(text)

  // AI metadata
  intent     String?
  aiModel    String?
  tokensUsed Int?

  // Tool calls and references (JSON)
  toolCalls  Json?
  references Json?

  // User feedback
  userFeedback Json?

  createdAt DateTime @default(now())

  // Relations
  session ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([sessionId])
  @@index([messageId])
}

enum ChatMessageRole {
  user
  assistant
  system
}

enum ChatContentType {
  text
  rich
  quick_reply
  card
}

// Chatbot configuration per organization
model ChatbotConfig {
  id             String @id @default(uuid())
  organizationId String @unique

  // AI Configuration
  aiModel       String @default("gpt-4o-mini")
  aiTemperature Float  @default(0.7)
  aiMaxTokens   Int    @default(2000)

  // Custom API Key (per-organization)
  // Optional: if provided, this will be used instead of the global system API key
  aiApiKey     String? @map("ai_api_key")
  aiApiBaseUrl String? @map("ai_api_base_url") // Custom endpoint for proxies/self-hosted models

  // Embedding Configuration (separate from LLM config for flexibility)
  embeddingModel   String  @default("text-embedding-3-small") // OpenAI default
  embeddingBaseUrl String? @map("embedding_base_url") // Custom endpoint for embedding API
  embeddingEnabled Boolean @default(true) @map("embedding_enabled") // Enable/disable KB embedding search

  // Reasoning Configuration (for DeepSeek thinking mode)
  reasoningEnabled Boolean @default(false) @map("reasoning_enabled")

  // Personality
  chatbotName     String  @default("Helix Assistant")
  greetingMessage String  @default("Hello! How can I help you today?")
  systemPrompt    String?

  // Behavior
  autoEscalateAfter Int      @default(5)
  escalateKeywords  String[] @default(["human", "agent", "real person"])

  // Custom FAQs (JSON array)
  customFaqs Json?

  // Feature flags
  enabledFeatures Json? // Array of enabled features

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
